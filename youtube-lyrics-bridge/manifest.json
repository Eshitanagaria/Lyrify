{
  "manifest_version": 3,
  "name": "YouTube Lyrics Bridge",
  "version": "1.0.0",
  "description": "Sends the currently playing YouTube video's timing info to the local Lyrics Overlay app.",
  "permissions": ["scripting", "alarms"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
